<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/radius_sm"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md">

        <!-- Scan Icon -->
        <FrameLayout
            android:layout_width="@dimen/icon_lg"
            android:layout_height="@dimen/icon_lg"
            android:background="@drawable/bg_scan_icon">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:layout_gravity="center"
                android:src="@drawable/ic_qr"
                app:tint="@color/primary"
                android:contentDescription="Scan icon"/>
        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_md">

            <TextView
                android:id="@+id/tvScanCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_md"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.03"
                android:maxLines="1"
                android:ellipsize="middle"
                tools:text="ABC123456789"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvScanTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary"
                    tools:text="11:25:30"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvScanPda"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/primary"
                    android:fontFamily="sans-serif-medium"
                    tools:text="PDA-MOBY-01"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Status Badge -->
        <FrameLayout
            android:id="@+id/statusBadgeContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvSendStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_xs"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="2dp"
                android:background="@drawable/badge_success"
                tools:text="Gui OK"/>
        </FrameLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
