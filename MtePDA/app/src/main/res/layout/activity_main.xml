<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_lg">

            <!-- Title Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_md">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_qr"
                    app:tint="@color/white"
                    android:contentDescription="Scanner icon"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="@dimen/spacing_sm"/>

                <!-- Server Status -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_status_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="@dimen/spacing_sm">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle_online"/>

                    <TextView
                        android:id="@+id/tvServerStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_checking"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Settings Button -->
                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/white"
                    android:contentDescription="Cài đặt"/>
            </LinearLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:paddingVertical="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tvTotalScans"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_total"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:alpha="0.8"
                        android:textAllCaps="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:paddingVertical="@dimen/spacing_md"
                    android:layout_marginHorizontal="@dimen/spacing_sm">

                    <TextView
                        android:id="@+id/tvTodayScans"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_today"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:alpha="0.8"
                        android:textAllCaps="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:paddingVertical="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tvLast24hScans"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_24h"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:alpha="0.8"
                        android:textAllCaps="true"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Scan Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_md"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_md"
                        android:background="@color/bg">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/hint_code"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold"
                            android:textAllCaps="true"/>

                        <TextView
                            android:id="@+id/tvScanCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 lần quét"
                            android:textSize="@dimen/text_xs"
                            android:textColor="@color/primary"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/badge_scan_count"
                            android:paddingHorizontal="@dimen/spacing_sm"
                            android:paddingVertical="2dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border"/>

                    <!-- Input + Send -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center_vertical">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:boxCornerRadiusBottomEnd="@dimen/radius_sm"
                            app:boxCornerRadiusBottomStart="@dimen/radius_sm"
                            app:boxCornerRadiusTopEnd="@dimen/radius_sm"
                            app:boxCornerRadiusTopStart="@dimen/radius_sm"
                            app:boxStrokeColor="@color/primary"
                            app:hintTextColor="@color/primary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/hint_code"
                                android:textSize="@dimen/text_lg"
                                android:fontFamily="monospace"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:inputType="text"
                                android:maxLines="1"
                                android:imeOptions="actionSend"
                                android:text=""
                                android:autofillHints="none"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_send"
                            android:textAllCaps="false"
                            app:cornerRadius="@dimen/radius_sm"
                            app:icon="@drawable/ic_send"
                            app:iconGravity="textStart"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border"/>

                    <!-- Scan Mode Indicator -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_sm"
                        android:background="@color/bg">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/che_doquet"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold"
                            android:textAllCaps="true"/>

                        <TextView
                            android:id="@+id/tvScanModeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mode_quet_thung"
                            android:textSize="@dimen/text_sm"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/badge_mode_quet"
                            android:paddingHorizontal="@dimen/spacing_md"
                            android:paddingVertical="4dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border"/>

                    <!-- Mode Selection Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnScan"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/mode_quet_thung"
                            android:textAllCaps="false"
                            android:textSize="@dimen/text_md"
                            android:paddingHorizontal="@dimen/spacing_xl"
                            app:cornerRadius="@dimen/radius_lg"
                            app:icon="@drawable/ic_scan"
                            app:iconGravity="textStart"
                            android:backgroundTint="@color/primary"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnKiemTra"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="@string/mode_kiem_tra"
                            android:textAllCaps="false"
                            android:textSize="@dimen/text_md"
                            android:paddingHorizontal="@dimen/spacing_xl"
                            app:cornerRadius="@dimen/radius_lg"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="@color/primary"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- History Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:src="@drawable/ic_history"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Lịch sử"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_history"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:textAllCaps="true"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_clear_history"
                    android:textAllCaps="false"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:textColor="@color/error"
                    android:textSize="@dimen/text_sm"/>
            </LinearLayout>

            <!-- RecyclerView History -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_scan_history"/>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_xl"
                android:visibility="visible">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_history"
                    android:alpha="0.3"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Trống"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_history"
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_history_hint"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/text_secondary"
                    android:alpha="0.7"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
